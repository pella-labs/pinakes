# ============================================================================
# KG-MCP — environment variables
# Copy to .env and fill in. .env is gitignored.
# ============================================================================

# --- Paths -------------------------------------------------------------------
# Required in `kg serve` mode. Points to the project's .pharos/wiki directory.
KG_WIKI_PATH=

# Optional. Defaults to ~/.pharos/profile. Personal KG lives here.
KG_PROFILE_PATH=

# --- Embedder selection ------------------------------------------------------
# One of: transformers | ollama | voyage | openai
# Default (bundled, zero-network): transformers
KG_EMBED_PROVIDER=transformers

# Provider-specific model name (defaults to Xenova/all-MiniLM-L6-v2-quantized
# for transformers).
KG_EMBED_MODEL=

# --- Ollama (only if KG_EMBED_PROVIDER=ollama) --------------------------------
KG_OLLAMA_URL=http://localhost:11434
KG_OLLAMA_MODEL=nomic-embed-text

# --- API keys (only if configured) -------------------------------------------
# NEVER commit these. Never log them from our code.
KG_VOYAGE_API_KEY=
KG_OPENAI_API_KEY=

# --- Sandbox runtime tuning --------------------------------------------------
KG_MAX_MEMORY_MB=64
KG_MAX_TIMEOUT_MS=10000
KG_WARM_POOL_SIZE=2

# --- Observability -----------------------------------------------------------
# pino level: trace | debug | info | warn | error | fatal
KG_LOG_LEVEL=info

# Project-scope audit JSONL mirror path (per CLAUDE.md privacy rule — personal
# scope audit rows go to ~/.pharos/profile/kg-audit.jsonl regardless).
KG_AUDIT_JSONL_PATH=.pharos/kg-audit.jsonl
