# ============================================================================
# Pinakes — environment variables
# Copy to .env and fill in. .env is gitignored.
# ============================================================================

# --- Paths -------------------------------------------------------------------
# Optional. Root directory for all Pinakes data. Defaults to ~/.pinakes.
# Project data stored under $PINAKES_ROOT/projects/<mangled-project-root>/
# Personal data stored directly under $PINAKES_ROOT/
PINAKES_ROOT=

# Optional override. Points to the project wiki directory.
# Default: $PINAKES_ROOT/projects/<mangled-cwd>/wiki
PINAKES_WIKI_PATH=

# --- Embedder selection ------------------------------------------------------
# One of: transformers | ollama | voyage | openai
# Default (bundled, zero-network): transformers
PINAKES_EMBED_PROVIDER=transformers

# Provider-specific model name (defaults to Xenova/all-MiniLM-L6-v2-quantized
# for transformers).
PINAKES_EMBED_MODEL=

# --- Ollama (only if PINAKES_EMBED_PROVIDER=ollama) --------------------------
PINAKES_OLLAMA_URL=http://localhost:11434
PINAKES_OLLAMA_MODEL=nomic-embed-text

# --- API keys (only if configured) -------------------------------------------
# NEVER commit these. Never log them from our code.
PINAKES_VOYAGE_API_KEY=
PINAKES_OPENAI_API_KEY=

# --- Sandbox runtime tuning --------------------------------------------------
PINAKES_MAX_MEMORY_MB=64
PINAKES_MAX_TIMEOUT_MS=10000
PINAKES_WARM_POOL_SIZE=2

# --- Observability -----------------------------------------------------------
# pino level: trace | debug | info | warn | error | fatal
PINAKES_LOG_LEVEL=info

# Audit JSONL paths are now derived automatically:
#   project → ~/.pinakes/projects/<mangled>/audit.jsonl
#   personal → ~/.pinakes/audit.jsonl
