{
  "name": "@pella-labs/pinakes",
  "version": "0.3.15",
  "description": "Local stdio MCP server that indexes a Karpathy-style two-level knowledge wiki into SQLite and exposes it to a coding LLM via Cloudflare-style code-mode.",
  "type": "module",
  "bin": {
    "pinakes": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^24.10.0",
    "pnpm": ">=10.30.0"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/db/migrations && cp -r src/db/migrations dist/db/migrations && chmod +x dist/cli/index.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:privacy": "vitest run src/__tests__/privacy --passWithNoTests",
    "test:budget": "vitest run src/__tests__/budget --passWithNoTests",
    "eval:tool-selection": "tsx src/__tests__/eval/tool-selection.eval.ts",
    "eval:tool-selection:pinakes": "tsx src/__tests__/eval/tool-selection.eval.ts --pinakes-only",
    "eval:variants": "tsx src/__tests__/eval/run-variants.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "pinakes": "tsx src/cli/index.ts",
    "prepublishOnly": "pnpm run build",
    "publish:npm": "pnpm publish --access public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.0",
    "acorn": "^8.16.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.0",
    "drizzle-orm": "^0.45.0",
    "js-tiktoken": "^1.0.0",
    "mdast-util-from-markdown": "^2.0.0",
    "micromark": "^4.0.0",
    "pino": "^9.0.0",
    "quickjs-emscripten": "^0.32.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@anthropic-ai/claude-code": "^2.1.101",
    "@anthropic-ai/sdk": "^0.88.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
